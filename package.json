{
  "name": "clipboard-manager",
  "version": "1.0.0",
  "description": "跨平台剪贴板管理器 - 支持文字和图片复制粘贴历史记录",
  "main": "src/main/index.js",
  "scripts": {
    "dev:renderer": "vite",
    "dev:electron": "wait-on http://localhost:5173 && electron .",
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:electron\"",
    "build:renderer": "vite build",
    "build:win": "npm run build:renderer && electron-builder --win",
    "build:mac": "npm run build:renderer && electron-builder --mac",
    "build": "npm run build:renderer && electron-builder --win --mac"
  },
  "dependencies": {
    "sql.js": "^1.11.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.0",
    "concurrently": "^9.1.0",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.0",
    "vite": "^6.0.0",
    "vue": "^3.5.0",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.clipboard.manager",
    "productName": "ClipboardManager",
    "files": [
      "src/main/**/*",
      "src/preload/**/*",
      "dist/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "extraResources": [],
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ClipboardManager"
    }
  }
}
